# Database Configuration
DB_NAME=biokey_db
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=10
DB_TIMEOUT=5

# API Configuration
API_PORT=4567
API_BIND=0.0.0.0
APP_ENV=development
APP_SESSION_SECRET=change_me_in_production_min_32_chars_long_123
APP_REQUIRE_HTTPS=false

# Rate Limiting
AUTH_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_WINDOW_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
BCRYPT_COST=12
TOKEN_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=30
SESSION_TOKEN_PEPPER=change_me_strong_pepper

# Feature Flags
ENABLE_PROTOTYPE=true
ENABLE_ADMIN_DASHBOARD=true
ENABLE_STRUCTURED_LOGGING=true
ENABLE_METRICS=false
ENABLE_ADVANCED_INTELLIGENCE=true

# Optional: Advanced Features
ML_MODEL_PATH=
EDGE_COMPUTE_ENABLED=false
